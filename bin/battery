#!/bin/sh
state=$( cat /sys/class/power_supply/BAT1/status | awk '{print $1;}' )
battery_level=$( cat /sys/class/power_supply/BAT1/capacity )

if [ $state = 'Not' ] || [ $state = 'Charging' ] || [ $state = 'Full'  ]; then
    icon='≤░γξ'
else
    case $battery_level in
	100)
	    icon=ΎΚΑ
        ;;

    [75-99])
	    icon=ΎΚΒ
        ;;

	[50-74])
	    icon=ΎΚΓ
        ;;

	[10-49])
	    icon=ΎΚΔ
        ;;

	[0-10])
	    icon=ΎΚΕ
	;;
    esac
fi

echo $icon $battery_level'%'
